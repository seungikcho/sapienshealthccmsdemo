# npm (e.g. AWS Elastic Beanstalk's default installer) treats the stale peer
# range of @builder.io/vite-plugin-jsx-loc (vite ^4||^5) against vite 7 as a
# fatal ERESOLVE error. The plugin works fine with vite 7 at build time, so we
# relax the peer check. pnpm ignores this setting (it only warns, never fails).
legacy-peer-deps=true
