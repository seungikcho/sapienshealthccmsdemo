# Google OAuth2 — create at console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Must EXACTLY match an Authorized redirect URI in the Google console
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Where the callback sends the doctor after a successful connect
CLIENT_POST_AUTH_URL=http://localhost:3000/patients

# express-session signing secret — use a long random string
SESSION_SECRET=change-me-to-a-long-random-string

# Express API port in dev (Vite proxies /api here)
API_PORT=3001
